# Copy to .env and fill in values.
# Loaded automatically by devenv (dotenv.enable = true).

# SITE_URL=https://example.com

# Primary LDraw asset base served by Vite (default: /ldraw).
# VITE_LDRAW_BASE=/ldraw
# Example deployment override:
# VITE_LDRAW_BASE=https://kehys.palikkaharrastajat.fi/ldraw/

# Optional Vite asset base path (default: /). Set in CI for GitHub Pages.
# Example:
# VITE_PUBLIC_BASE=/technic/

# Optional fallback base for missing parts (default: disabled).
# Example:
# VITE_LDRAW_FALLBACK_BASE=https://raw.githubusercontent.com/gkjohnson/ldraw-parts-library/master/complete/ldraw

# Max RPM for motor slider (default: 50).
# VITE_MAX_RPM=50
